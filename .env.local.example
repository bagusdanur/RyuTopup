# RyuTopup Supabase Configuration
# Salin file ini menjadi .env.local dan isi dengan kredensial proyek Supabase Anda.

# Publik - Dapat diakses oleh client
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Privat - HANYA boleh diakses di sisi server (API Route / Server Action)
# JANGAN PERNAH membocorkan service role key ke sisi client!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Kustomisasi RyuTopup
# Nomor WhatsApp Customer Service (format internasional tanpa tanda +, contoh: 628123456789)
NEXT_PUBLIC_CS_WHATSAPP=628123456789
